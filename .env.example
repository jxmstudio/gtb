# TOFA Group — environment variables
# Copy this file to .env.local for local development and set real values.
# In production, configure these in the Vercel project dashboard (Settings → Environment Variables).

# --- Analytics ---
# Google Analytics 4 measurement ID. Create a GA4 property at analytics.google.com
# and paste the G-XXXXXXXXXX ID here. Leave blank to disable GA4 injection.
NEXT_PUBLIC_GA_ID=

# --- Lead form ---
# Google Apps Script webhook URL that appends lead submissions to the TOFA lead tracker sheet.
# See src/app/api/lead/route.ts for the payload shape.
GOOGLE_SHEETS_WEBHOOK_URL=
